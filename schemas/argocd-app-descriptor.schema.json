{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://isaacwallace.dev/schemas/argocd-app-descriptor.schema.json",
  "title": "Homelab ArgoCD ApplicationSet descriptor",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "name",
    "namespace",
    "project",
    "syncWave",
    "repoURL",
    "targetRevision"
  ],
  "properties": {
    "name": {
      "type": "string",
      "pattern": "^[a-z0-9]([-a-z0-9]*[a-z0-9])?$"
    },
    "namespace": {
      "type": "string",
      "pattern": "^[a-z0-9]([-a-z0-9]*[a-z0-9])?$"
    },
    "project": {
      "type": "string",
      "enum": [
        "infrastructure",
        "applications",
        "monitoring",
        "lab-observability",
        "portfolio"
      ]
    },
    "syncWave": {
      "type": "string",
      "pattern": "^-?[0-9]+$"
    },
    "repoURL": {
      "type": "string",
      "minLength": 1
    },
    "targetRevision": {
      "type": "string",
      "minLength": 1
    },
    "chart": {
      "type": "string",
      "minLength": 1
    },
    "values": {
      "type": "string"
    },
    "appPath": {
      "type": "string",
      "comment": "Relative path within the source repo. The manifests/apps|manifests/infra convention is enforced by validate-gitops.py for homelab-sourced descriptors; externally-sourced descriptors (e.g. portfolio-v3) use the remote repo's own layout.",
      "pattern": "^[A-Za-z0-9._-]+(/[A-Za-z0-9._-]+)*$"
    }
  },
  "oneOf": [
    {
      "title": "Git manifest application",
      "required": [
        "appPath"
      ],
      "not": {
        "anyOf": [
          {
            "required": [
              "chart"
            ]
          },
          {
            "required": [
              "values"
            ]
          }
        ]
      }
    },
    {
      "title": "Helm chart application",
      "required": [
        "chart",
        "values"
      ],
      "not": {
        "required": [
          "appPath"
        ]
      }
    }
  ]
}
