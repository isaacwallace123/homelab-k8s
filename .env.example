# ============================================================
# HOMELAB KUBERNETES CONFIG — pve2 / k3s-homelab VM
# Copy to .env and fill in your values
# ============================================================

# --- Domain ---
DOMAIN=homelab.local
# Set to your real domain for external access
# For local-only, you can use homelab.local and point via AdGuard DNS or /etc/hosts

# --- Storage (ZFS tank passthrough via virtiofs) ---
DATA_ROOT=/mnt/k3s-data
# This maps to tank/k3s-data on pve2 via virtiofs

# --- Media Library Paths (ZFS tank/media via virtiofs) ---
MEDIA_MOVIES=/mnt/media/movies
MEDIA_TV=/mnt/media/tv
MEDIA_DOWNLOADS=/mnt/media/downloads

# --- Timezone ---
TZ=America/New_York

# --- PUID/PGID (for *arr apps and Plex) ---
PUID=1000
PGID=1000

# --- Node IP ---
NODE_IP=192.168.0.10

# --- Plex ---
PLEX_CLAIM=
# Get at https://plex.tv/claim (valid 4 minutes)

# --- Deluge VPN ---
VPN_ENABLED=yes
VPN_PROV=pia
VPN_USER=your_vpn_username
VPN_PASS=your_vpn_password
LAN_NETWORK=192.168.0.0/24

# --- Authentik ---
AUTHENTIK_SECRET_KEY=changeme-generate-with-openssl-rand-base64-36
AUTHENTIK_POSTGRES_PASSWORD=changeme-authentik-db-pass
AUTHENTIK_EMAIL_HOST=smtp.gmail.com
AUTHENTIK_EMAIL_PORT=587
AUTHENTIK_EMAIL_USERNAME=
AUTHENTIK_EMAIL_PASSWORD=
AUTHENTIK_EMAIL_FROM=

# --- Mattermost ---
MATTERMOST_DB_PASSWORD=changeme-mattermost-db-pass

# --- Kimai ---
KIMAI_DB_PASSWORD=changeme-kimai-db-pass
KIMAI_ADMIN_EMAIL=admin@example.com
KIMAI_ADMIN_PASSWORD=changeme-kimai-admin

# --- Grafana ---
GRAFANA_ADMIN_PASSWORD=changeme-grafana-admin

# --- Portfolio ---
PORTFOLIO_GITHUB_REPO=https://github.com/yourusername/portfolio.git
PORTFOLIO_BRANCH=main

# --- Cert Manager (optional) ---
LETSENCRYPT_EMAIL=
ACME_SERVER=https://acme-v02.api.letsencrypt.org/directory

# ============================================================
# PARENT ACCESS (same network):
#   Plex:    http://192.168.0.10:32400/web
#   Sonarr:  http://sonarr.yourdomain.com
#   Radarr:  http://radarr.yourdomain.com
#   AdGuard: set router DNS to MetalLB IP (192.168.0.20-30)
#
# Use AdGuard DNS rewrites for clean local URLs:
#   plex.yourdomain.com   → 192.168.0.10
#   sonarr.yourdomain.com → 192.168.0.10
#   etc.
# ============================================================
