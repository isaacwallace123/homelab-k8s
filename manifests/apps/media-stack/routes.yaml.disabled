# ── Media stack HTTPS routes ───────────────────────────────────────────────────
# All resolved via: *.lan → 192.168.0.245 in AdGuard
apiVersion: gateway.networking.k8s.io/v1
kind: HTTPRoute
metadata:
  name: overseerr
  namespace: media
spec:
  parentRefs:
    - group: gateway.networking.k8s.io
      kind: Gateway
      name: envoy-gateway
      namespace: networking
      sectionName: https-lan
  hostnames:
    - overseerr.lan
  rules:
    - matches:
        - path:
            type: PathPrefix
            value: /
      backendRefs:
        - group: ""
          kind: Service
          name: overseerr
          port: 5055
          weight: 1
---
